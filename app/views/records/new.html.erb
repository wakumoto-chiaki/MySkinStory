<div class="min-h-screen flex items-center justify-center px-6">

  <div class="w-full max-w-md">

    <h2 class="text-3xl font-extralight tracking-wide text-gray-700 text-center">
      経過記録を追加
    </h2>

    <p class="mt-4 text-center text-sm text-gray-400">
      今日の肌の様子を記録しましょう
    </p>

    <%= form_with model: [@story, @record], local: true, class: "mt-10" do |f| %>

      <%= render "devise/shared/error_messages", resource: @record %>

      <div class="mt-6">
        <%= f.label :recorded_on,
            "記録日",
            class: "block text-sm text-gray-500 mb-2" %>

        <%= f.date_field :recorded_on,
            class: "w-full border border-gray-200 rounded-xl px-4 py-3 focus:outline-none focus:ring-2 focus:ring-rose-200" %>
      </div>

      <div class="mt-6">
        <%= f.label :image,
            "写真",
            class: "block text-sm text-gray-500 mb-2" %>

        <%= f.file_field :image,
            class: "w-full border border-gray-200 rounded-xl px-4 py-3" %>
      </div>
      
      <div class="mt-6">
        <%= f.label :memo,
            "メモ",
            class: "block text-sm text-gray-500 mb-2" %>

        <%= f.text_area :memo,
            rows: 6,
            class: "w-full border border-gray-200 rounded-xl px-4 py-3 focus:outline-none focus:ring-2 focus:ring-rose-200" %>
      </div>

      <div class="mt-10">
        <%= f.submit "記録を投稿する",
            class: "w-full bg-rose-300 hover:bg-rose-400 text-white py-3 rounded-full transition duration-300" %>
      </div>

    <% end %>

    <div class="mt-8 text-center">
      <%= link_to "戻る",
          story_path(@story),
          class: "text-sm text-gray-400 hover:text-rose-300 transition duration-300" %>
    </div>

  </div>

</div>