<div class="max-w-3xl mx-auto px-6 py-12">

  <h1 class="text-4xl font-extralight text-gray-700">
    <%= @story.title %>
  </h1>

  <p class="mt-6 text-gray-500 leading-8">
    <%= @story.description %>
  </p>

  <div class="mt-8 text-sm text-gray-400">
    開始日：<%= @story.started_on %>
  </div>
  <div class="mt-12">
    <h2 class="text-2xl font-light text-gray-700 mb-6">
      Before / After
    </h2>

    <div class="grid grid-cols-2 gap-6">

      <div class="border border-gray-200 rounded-2xl p-4">
        <p class="text-xs tracking-widest uppercase text-rose-300 mb-3">
          Before
        </p>

        <% if @before_record&.image&.attached? %>
          <%= image_tag @before_record.image,
              class: "w-full rounded-xl" %>
        <% else %>
          <div class="aspect-square bg-gray-100 rounded-xl flex items-center justify-center text-gray-400">
            No Image
          </div>
        <% end %>

        <% if @before_record %>
          <p class="mt-3 text-sm text-gray-500">
            <%= @before_record.recorded_on %>
          </p>
        <% end %>
      </div>

      <div class="border border-gray-200 rounded-2xl p-4">
        <p class="text-xs tracking-widest uppercase text-rose-300 mb-3">
          After
        </p>

        <% if @after_record&.image&.attached? %>
          <%= image_tag @after_record.image,
              class: "w-full rounded-xl" %>
        <% else %>
          <div class="aspect-square bg-gray-100 rounded-xl flex items-center justify-center text-gray-400">
            No Image
          </div>
        <% end %>

        <% if @after_record %>
          <p class="mt-3 text-sm text-gray-500">
            <%= @after_record.recorded_on %>
          </p>
        <% end %>
      </div>

    </div>
  </div>

  <hr class="my-12 border-gray-200">

  <h2 class="text-2xl font-light text-gray-700">
    経過記録
  </h2>

  <%= link_to "＋ 経過記録を追加",
      new_story_record_path(@story),
      class: "inline-block mt-6 bg-rose-300 hover:bg-rose-400 text-white px-6 py-3 rounded-full transition duration-300" %>

  <% if @story.records.any? %>

    <% @story.records.each do |record| %>

      <div class="mt-6 border border-gray-200 rounded-2xl p-6">

        <p class="text-sm text-gray-400">
          <%= record.recorded_on %>
        </p>

        <% if record.image.attached? %>
          <%= image_tag record.image,
              class: "w-full rounded-xl my-4" %>
        <% end %>

        <p class="text-gray-600 leading-7">
          <%= record.memo %>
        </p>

        <div class="mt-4">
          <%= link_to "編集",
              edit_story_record_path(@story, record),
              class: "text-sm text-rose-400 hover:text-rose-500 transition duration-300" %>
        
          <%= button_to "削除",
              story_record_path(@story, record),
              method: :delete,
              form_class: "inline-block ml-4",
              class: "text-sm text-gray-400 hover:text-red-500 transition duration-300",
              data: {
                turbo_confirm: "この経過記録を削除しますか？"
             } %>
        
        
        </div>


      </div>

    <% end %>

  <% else %>

    <p class="mt-6 text-gray-400">
      まだ経過記録はありません
    </p>

  <% end %>

  <%= link_to "編集する",
      edit_story_path(@story),
      class: "inline-block mt-8 bg-rose-300 hover:bg-rose-400 text-white px-6 py-3 rounded-full transition duration-300" %>

  <%= button_to "削除する",
      story_path(@story),
      method: :delete,
      form_class: "inline-block",
      class: "bg-gray-300 hover:bg-gray-400 text-white px-6 py-3 rounded-full transition duration-300",
      data: {
        turbo_confirm: "本当にこのストーリーを削除しますか？"
      } %>
       
</div>
