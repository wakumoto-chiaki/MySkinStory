<div class="max-w-4xl mx-auto px-6 py-12">

  <div class="flex items-center justify-between mb-10">
    <h1 class="text-3xl font-extralight text-gray-700">
      My Stories
    </h1>

    <%= link_to "＋ 新しいストーリー",
        new_story_path,
        class: "bg-rose-300 hover:bg-rose-400 text-white px-5 py-3 rounded-full transition duration-300" %>
  </div>

  <% if @stories.any? %>

    <% @stories.each do |story| %>

      <div class="border border-gray-200 rounded-2xl p-6 mb-6">

        <h2 class="text-xl">
          <%= link_to story.title,
            story_path(story),
            class: "text-gray-700 hover:text-rose-300 transition duration-300" %>
        </h2>

        <p class="mt-3 text-gray-500">
          <%= story.description %>
        </p>

        <p class="mt-4 text-sm text-gray-400">
          開始日：<%= story.started_on %>
        </p>

      </div>

    <% end %>

  <% else %>

    <div class="text-center py-20">
      <p class="text-gray-400">
        まだストーリーがありません
      </p>
    </div>

  <% end %>

</div>