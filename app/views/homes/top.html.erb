<header class="max-w-7xl mx-auto flex justify-between items-center px-6 py-6">
  <h1 class="text-xl font-light tracking-wide text-rose-200">
    My Skin Story
  </h1>

  <a href="#"
     class="flex items-center gap-2 text-sm text-gray-500 hover:text-rose-300 transition duration-300">

    <span class="text-lg">
      ♙
    </span>

    Login
  </a>
</header>


<main class="max-w-7xl mx-auto px-6">

  <section class="min-h-[calc(100vh-88px)] grid md:grid-cols-2 gap-12 items-center">

    <!-- 左側：メッセージ -->
    <div class="order-2 md:order-1">

      <h2 class="text-4xl md:text-6xl font-extralight tracking-wide leading-tight text-gray-700">
        肌の変化を、<br>
        <span class="text-rose-300">
          ストーリーに。
        </span>
      </h2>


      <p class="mt-8 text-gray-500 leading-8">
        美容医療で変わっていく毎日を、<br>
        あなただけのアルバムとして残そう。
      </p>


      <a href="#"
         class="inline-flex items-center justify-center gap-4 mt-10 bg-rose-300 hover:bg-rose-400 text-white px-10 py-4 rounded-full transition duration-300">

        新規登録

        <span>
          →
        </span>

      </a>

    </div>



    <!-- 右側：画像 -->
    <div class="order-1 md:order-2">

      <div class="rounded-3xl overflow-hidden h-[420px] md:h-[650px]">

        <%= image_tag "hero.jpg",
          class: "w-full h-full object-cover" %>

      </div>

    </div>

  </section>


  <!-- Scroll -->
  <div class="hidden md:flex flex-col items-center text-rose-200 pb-10">

    <span class="text-xs tracking-widest">
      SCROLL
    </span>

    <span class="mt-3">
      ↓
    </span>

  </div>

</main>



<footer class="text-center py-8 text-sm text-gray-400">
  © My Skin Story
</footer>
