<div class="min-h-screen flex items-center justify-center px-6 bg-white">
  <div class="w-full max-w-md">


    <div class="text-center mb-10">
      <h1 class="text-2xl font-light tracking-wide text-rose-300">
        My Skin Story
      </h1>

      <h2 class="mt-6 text-3xl font-extralight text-gray-700">
        ログイン
      </h2>

      <p class="mt-3 text-gray-500 leading-7">
        あなたの肌変化ストーリーへ戻りましょう
      </p>
    </div>


    <%= form_for(resource, as: resource_name, url: session_path(resource_name)) do |f| %>


      <div class="mb-6">
        <%= f.label :email, "メールアドレス",
          class: "block text-sm font-medium text-gray-600 mb-2" %>

        <%= f.email_field :email,
          autofocus: true,
          autocomplete: "email",
          class: "w-full rounded-xl border border-gray-200 px-4 py-3 focus:border-rose-300 focus:ring-rose-300" %>
      </div>


      <div class="mb-6">
        <%= f.label :password, "パスワード",
          class: "block text-sm font-medium text-gray-600 mb-2" %>

        <%= f.password_field :password,
          autocomplete: "current-password",
          class: "w-full rounded-xl border border-gray-200 px-4 py-3 focus:border-rose-300 focus:ring-rose-300" %>
      </div>


      <% if devise_mapping.rememberable? %>
        <div class="mb-6 flex items-center gap-2 text-sm text-gray-500">
          <%= f.check_box :remember_me %>
          <%= f.label :remember_me, "ログイン状態を保持する" %>
        </div>
      <% end %>


      <div>
        <%= f.submit "ログイン",
          class: "w-full bg-rose-300 hover:bg-rose-400 text-white py-3 rounded-full transition duration-300 cursor-pointer" %>
      </div>


    <% end %>


    <div class="mt-8 text-center text-sm text-gray-500">
      <%= render "devise/shared/links" %>
    </div>


  </div>
</div>